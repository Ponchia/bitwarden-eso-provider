{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "singleOriginUrl": {
          "type": "string"
        },
        "identityUrl": {
          "type": "string"
        },
        "apiUrl": {
          "type": "string"
        },
        "cacheTtlSeconds": {
          "type": ["integer", "string"],
          "pattern": "^[0-9]+$",
          "minimum": 0
        },
        "deviceIdentifier": {
          "type": "string"
        },
        "deviceName": {
          "type": "string"
        },
        "deviceType": {
          "type": ["integer", "string"],
          "pattern": "^[0-9]+$",
          "minimum": 0,
          "maximum": 255
        }
      }
    },
    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "keys": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "clientId": {
                  "type": "string"
                },
                "clientSecret": {
                  "type": "string"
                },
                "masterPassword": {
                  "type": "string"
                }
              }
            }
          }
        },
        "create": {
          "type": "boolean"
        },
        "clientId": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "masterPassword": {
          "type": "string"
        }
      }
    }
  }
}
