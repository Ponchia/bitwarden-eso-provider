{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": ["integer", "string"],
      "pattern": "^[0-9]+$",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "automount": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "podAnnotations": {
      "type": "object"
    },
    "podLabels": {
      "type": "object"
    },
    "priorityClassName": {
      "type": "string"
    },
    "terminationGracePeriodSeconds": {
      "type": ["integer", "string"],
      "pattern": "^[1-9][0-9]*$",
      "minimum": 1
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": ["integer", "string"],
          "pattern": "^[1-9][0-9]*$",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "singleOriginUrl": {
          "type": "string"
        },
        "identityUrl": {
          "type": "string"
        },
        "apiUrl": {
          "type": "string"
        },
        "cacheTtlSeconds": {
          "type": ["integer", "string"],
          "pattern": "^[0-9]+$",
          "minimum": 0
        },
        "httpConnectTimeoutSeconds": {
          "type": ["integer", "string"],
          "pattern": "^[1-9][0-9]*$",
          "minimum": 1
        },
        "httpRequestTimeoutSeconds": {
          "type": ["integer", "string"],
          "pattern": "^[1-9][0-9]*$",
          "minimum": 1
        },
        "deviceIdentifier": {
          "type": "string"
        },
        "deviceName": {
          "type": "string"
        },
        "deviceType": {
          "type": ["integer", "string"],
          "pattern": "^[0-9]+$",
          "minimum": 0,
          "maximum": 255
        }
      }
    },
    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "keys": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "clientId": {
                  "type": "string"
                },
                "clientSecret": {
                  "type": "string"
                },
                "masterPassword": {
                  "type": "string"
                },
                "webhookToken": {
                  "type": "string"
                }
              }
            }
          }
        },
        "create": {
          "type": "boolean"
        },
        "clientId": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "masterPassword": {
          "type": "string"
        },
        "webhookToken": {
          "type": "string"
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "insecureAllowUnauthenticated": {
          "type": "boolean"
        }
      }
    },
    "hostAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ip", "hostnames"],
        "properties": {
          "ip": {
            "type": "string",
            "minLength": 1
          },
          "hostnames": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "selectorPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowedKeyPrefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "ingress": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "egress": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rustLog": {
          "type": "string"
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startup": {
          "$ref": "#/definitions/probe"
        },
        "liveness": {
          "$ref": "#/definitions/probe"
        },
        "readiness": {
          "$ref": "#/definitions/probe"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "type": "string"
            },
            "labels": {
              "type": "object"
            },
            "annotations": {
              "type": "object"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "honorLabels": {
              "type": "boolean"
            },
            "relabelings": {
              "type": "array"
            },
            "metricRelabelings": {
              "type": "array"
            }
          }
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resources": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "definitions": {
    "probe": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "httpGet": {
          "type": "object"
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
